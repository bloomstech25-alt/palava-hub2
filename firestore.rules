rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Safe block check — uses .get('blockedUserIds', []) so a user whose doc
    // doesn't have the field yet (most users) doesn't trigger a rule error.
    // Returning false here means "not blocked", which is the correct default.
    function isBlockedBy(targetUid, viewerUid) {
      return exists(/databases/$(database)/documents/users/$(targetUid))
        && viewerUid in get(/databases/$(database)/documents/users/$(targetUid)).data.get('blockedUserIds', []);
    }

    function convParticipants(cid) {
      return cid.split('_');
    }

    function isConvParticipant(cid) {
      return isSignedIn()
        && (request.auth.uid == convParticipants(cid)[0]
            || request.auth.uid == convParticipants(cid)[1]);
    }

    function isValidReportReason(r) {
      return r in ['spam','harassment','hate_speech','violence','nudity','self_harm','misinformation','other'];
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid) && request.resource.data.id == uid;
      allow update: if (
        isSelf(uid) && (
          !('admin' in request.resource.data.keys())
          || request.resource.data.admin == resource.data.get('admin', false)
        )
      ) || (
        isSignedIn() && request.auth.uid != uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers','following','posts'])
      ) || isAdmin();
      allow delete: if isSelf(uid) || isAdmin();
    }

    match /users/{uid}/conversations/{otherId} {
      allow read: if isSelf(uid);
      allow write: if isSignedIn()
        && (request.auth.uid == uid || request.auth.uid == otherId)
        && !isBlockedBy(uid, request.auth.uid)
        && !isBlockedBy(otherId, request.auth.uid);
      allow delete: if isSelf(uid);
    }

    match /conversations/{cid}/messages/{msgId} {
      allow read: if isConvParticipant(cid);
      allow create: if isConvParticipant(cid)
        && request.resource.data.fromId == request.auth.uid
        && request.resource.data.toId in convParticipants(cid)
        && request.resource.data.toId != request.auth.uid
        && !isBlockedBy(request.resource.data.toId, request.auth.uid);
      allow update: if isConvParticipant(cid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read == true;
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if (
        isSignedIn() && resource.data.authorId == request.auth.uid
      ) || (
        isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes','likedBy','comments','shares','isFollowing','repostedBy'])
      ) || isAdmin();
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
      }
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending'
        && isValidReportReason(request.resource.data.reason)
        && request.resource.data.targetType in ['post','comment','user','message']
        && (
          !('targetUserId' in request.resource.data.keys())
          || request.resource.data.targetUserId == null
          || request.resource.data.targetUserId != request.auth.uid
        );
      allow update, delete: if isAdmin();
    }

    match /verificationRequests/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create, update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if (
        isSignedIn() && resource.data.ownerId == request.auth.uid
      ) || (
        isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['impressions','clicks'])
      ) || isAdmin();
      allow delete: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
    }

    match /pages/{pageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
    }

    match /palavaroomPosts/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
    }

    match /supportRequests/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /calls/{callId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.calleeId);
      allow create: if isSignedIn() && request.resource.data.callerId == request.auth.uid;
      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.calleeId);
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
